{
  "$schema": "./hook-variant.schema.json",
  "vendor": "codex",
  "hookDir": ".codex/hooks",
  "settingsFile": ".codex/hooks.json",
  "projectDirEnv": null,
  "runtime": "bun",
  "events": {
    "UserPromptSubmit": [
      {
        "hook": "keyword-detector.ts",
        "timeout": 5
      },
      {
        "hook": "state-boundary.ts",
        "timeout": 5
      },
      {
        "hook": "skill-injector.ts",
        "timeout": 3
      },
      {
        "hook": "serena-primer.ts",
        "timeout": 3
      }
    ],
    "PreToolUse": [
      {
        "hook": "scm-guard.ts",
        "matcher": "Bash",
        "timeout": 3
      },
      {
        "hook": "test-filter.ts",
        "matcher": "Bash",
        "timeout": 5
      }
    ],
    "Stop": {
      "hook": "persistent-mode.ts",
      "timeout": 5
    }
  }
}
