# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs
dist/
build/
*.js.map
bin/*.js
/cli/bin/
!scripts/dashboard-web/**/*.js
!scripts/generate-manifest.js

# Environment
.env
.env.local
.env.*.local

# OMA outputs
.agents/plan.json
docs/plans/
docs/exec-plans/

# Claude/Codex/Qwen integration layer (generated)
.claude/
.codex/
.qwen/

# Cursor/Gemini integration layer (generated)
.cursor/*
.gemini/*

# NOTE: .apm/ is a generated MIRROR of .agents/skills/ for APM distribution.
# It MUST be committed (consumers install via git clone). Do NOT add .apm/ here.
# Regenerate with: bun run build:apm

# Serena Memory (runtime state)
.serena/memories/*
!.serena/memories/.gitkeep

# Serena runtime (nested workspaces)
cli/.serena/
web/.serena/

# OMA runtime state (hook persistent mode)
.agents/state/
.agents/results/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/
test-results/

# Temporary files
*.tmp
*.temp
.cache/

# OS
Thumbs.db

# Python
__pycache__/
*.pyc

.opencode/mimic/
.mimic/
.omc/
